generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(120)
  email        String         @unique @db.VarChar(120)
  passwordHash String         @map("password_hash") @db.VarChar(255)
  avatar       String         @default("CH") @db.VarChar(8)
  role         String         @default("user") @db.VarChar(20)
  addresses    Json           @default("[]")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  orders       Order[]
  refreshTokens RefreshToken[]

  @@index([email])
  @@map("users")
}

model Product {
  id            String   @id @db.VarChar(80)
  slug          String   @unique @db.VarChar(120)
  name          String   @db.VarChar(160)
  title         String?  @db.VarChar(160)
  category      String   @db.VarChar(120)
  brand         String?  @db.VarChar(120)
  price         Int
  discountPrice Int?     @map("discount_price")
  originalPrice Int?     @map("original_price")
  stock         Int      @default(0)
  images        Json     @default("[]")
  thumbnail     String?  @db.VarChar(500)
  tags          Json     @default("[]")
  visibilityStatus String @default("visible") @map("visibility_status") @db.VarChar(30)
  featured      Boolean  @default(false)
  popularity    Int      @default(0)
  rating        Float    @default(4.5)
  badge         String   @db.VarChar(80)
  summary       String
  description   String
  turnaround    String   @db.VarChar(80)
  features      Json     @default("[]")
  materials     Json     @default("[]")
  accent        String   @db.VarChar(16)
  surface       String   @db.VarChar(120)
  customizable  Boolean  @default(true)
  art           Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([slug])
  @@index([visibilityStatus])
  @@map("products")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(120)
  slug        String   @unique @db.VarChar(140)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("categories")
}

model Order {
  id              String   @id @db.VarChar(32)
  userId          Int      @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          String   @default("placed") @db.VarChar(40)
  total           Int
  paymentMethod   String   @map("payment_method") @db.VarChar(80)
  paymentRef      String?  @map("payment_ref") @db.VarChar(500)
  shippingAddress Json     @map("shipping_address")
  items           Json     @default("[]")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([createdAt])
  @@map("orders")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @map("token_hash") @db.VarChar(255)
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
