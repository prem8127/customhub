NODE_ENV=development
PORT=5001

# PostgreSQL — replace with your production DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/customhub

# Frontend URL (update for production)
FRONTEND_ORIGIN=http://localhost:3000

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-this-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Cookie signing secret — generate with: openssl rand -hex 32
COOKIE_SECRET=change-this-cookie-secret-min-32-chars

# Google OAuth (Authorization Code flow) — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Razorpay — leave blank to disable payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary — leave blank to disable image uploads
CLOUDINARY_URL=

# Admin account (created at first seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=CustomHub Admin

# Rate limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=120
